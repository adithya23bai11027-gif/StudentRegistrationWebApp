@model Student
@{ ViewData["Title"] = "Student Details"; }
<h1>Student Details</h1><hr />
<dl class="row"><dt class="col-sm-3">@Html.DisplayNameFor(model => model.FullName)</dt><dd class="col-sm-9">@Model.FullName</dd><dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.User?.Email</dd><dt class="col-sm-3">@Html.DisplayNameFor(model => model.City)</dt><dd class="col-sm-9">@Model.City</dd><dt class="col-sm-3">@Html.DisplayNameFor(model => model.Course)</dt><dd class="col-sm-9">@Model.Course?.CourseName</dd></dl>
<a class="btn btn-outline-secondary" asp-action="Index">Back to Students</a>
