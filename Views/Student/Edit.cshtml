@model Student
@{ ViewData["Title"] = "Edit Profile"; }
<h1>Edit My Profile</h1><hr />
<div class="row"><div class="col-md-6"><form asp-action="Edit" method="post"><input type="hidden" asp-for="StudentId" /><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="mb-3"><label asp-for="FullName" class="form-label"></label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger"></span></div><div class="mb-3"><label asp-for="City" class="form-label"></label><input asp-for="City" class="form-control" /><span asp-validation-for="City" class="text-danger"></span></div><div class="mb-3"><label asp-for="CourseId" class="form-label"></label><select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId"></select><span asp-validation-for="CourseId" class="text-danger"></span></div><button type="submit" class="btn btn-primary">Save Changes</button> <a asp-action="Profile" class="btn btn-outline-secondary">Cancel</a></form></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
