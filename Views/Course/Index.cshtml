@model IEnumerable<Course>
@{
    ViewData["Title"] = "Courses";
}
<div class="d-flex justify-content-between align-items-center mb-3"><h1>Courses</h1>@if (User.IsInRole("Administrator")){<a class="btn btn-success" asp-action="Create">Create Course</a>}</div>
<div class="table-responsive"><table class="table table-striped table-hover align-middle"><thead><tr><th>Course</th><th>Duration</th>@if (User.IsInRole("Administrator")){<th class="text-end">Actions</th>}</tr></thead><tbody>
@foreach (var course in Model){<tr><td>@course.CourseName</td><td>@course.CourseDuration months</td>@if (User.IsInRole("Administrator")){<td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@course.CourseId">Details</a> <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@course.CourseId">Edit</a> <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@course.CourseId">Delete</a></td>}</tr>}
</tbody></table></div>
