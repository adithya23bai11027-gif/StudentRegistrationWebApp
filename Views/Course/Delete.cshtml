@model Course
@{ ViewData["Title"] = "Delete Course"; }
<h1>Delete Course</h1><div class="alert alert-warning">Are you sure you want to delete this course?</div><dl class="row"><dt class="col-sm-3">@Html.DisplayNameFor(model => model.CourseName)</dt><dd class="col-sm-9">@Model.CourseName</dd><dt class="col-sm-3">@Html.DisplayNameFor(model => model.CourseDuration)</dt><dd class="col-sm-9">@Model.CourseDuration months</dd></dl>
<form asp-action="Delete" method="post"><input type="hidden" asp-for="CourseId" /><button type="submit" class="btn btn-danger">Delete</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></form>
